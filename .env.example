# Azure Blob Storage (app submissions)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_SUBMISSIONS_CONTAINER=app-submissions

# Resend email notifications
# RESEND_FROM must use a domain verified in Resend (e.g. TRBO Website <info@turbofasttools.com>)
RESEND_API_KEY=
RESEND_FROM=TRBO Website <info@turbofasttools.com>
SUBMISSIONS_EMAIL_TO=info@turbofasttools.com
