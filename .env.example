# Azure Blob Storage (app submissions)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_SUBMISSIONS_CONTAINER=app-submissions
# Top-level folder inside the container (e.g. turbo-web/submissions/..., turbo-web/rate-limit/...)
AZURE_STORAGE_PREFIX=turbo-web

# Resend email notifications
# RESEND_FROM must use your verified Resend domain: contact.turbofasttools.com
RESEND_API_KEY=
RESEND_FROM=TRBO Website <notifications@contact.turbofasttools.com>
SUBMISSIONS_EMAIL_TO=info@turbofasttools.com
